OPENAI_API_KEY=""
you@example.com=""
YOUR_PASSWORD_HERE=""

# Gmail IMAP/SMTP (see y/Gmail/ and FoXYiZ/f/.env.example)
GMAIL_EMAIL="you@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Stripe Checkout scaffold (public /pricing · /api/billing/*) — never commit real keys
APP_BASE_URL="http://127.0.0.1:8765"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MEMBERSHIP=""

# Google OAuth (Continue with Google on /login and /signup)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
JWT_SECRET="qoa-dev-change-me-in-production"

# Auth while testing (local + brahl.qaonair.com): keep guest/demo open.
# When Google OAuth is live: QOA_ALLOW_DEMO=0 and QOA_AUTH_REQUIRED=1
QOA_ALLOW_DEMO=1
QOA_AUTH_REQUIRED=0
