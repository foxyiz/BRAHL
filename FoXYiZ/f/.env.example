# Copy to f/.env and fill in real values. Never commit f/.env to git.
#
# Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords
# Use the 16-character app password (spaces optional) for GMAIL_APP_PASSWORD.

OPENAI_API_KEY=""

GMAIL_EMAIL="you@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# LinkedIn Developer App (optional — for PLinkedIn_OAuth_Token plan, Run=N by default)
# Create app: https://www.linkedin.com/developers/apps
# Most apps require authorization_code flow; client_credentials is limited.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Google OAuth for Arena /login and /signup (Continue with Google)
# https://console.cloud.google.com/apis/credentials
# Redirect URI: http://127.0.0.1:8765/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APP_BASE_URL="http://127.0.0.1:8765"

# Guest/demo into BRAHL until OAuth is wired (local + brahl.qaonair.com)
QOA_ALLOW_DEMO=1
QOA_AUTH_REQUIRED=0
