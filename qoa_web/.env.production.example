# Production environment for brahl.qaonair.com (qoa_web + FoXYiZ)
# Copy to the host as qoa_web/.env or export in the process manager.
# NEVER commit real secrets.

# --- Public URL ---
APP_BASE_URL=https://brahl.qaonair.com

# --- Auth ---
JWT_SECRET=replace-with-long-random-string
QOA_ALLOW_DEMO=1
QOA_AUTH_REQUIRED=0
QOA_ADMIN_OPEN=1
# After Google OAuth works, lock launch:
# QOA_ALLOW_DEMO=0
# QOA_AUTH_REQUIRED=1
# QOA_ADMIN_OPEN=0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI in Google Cloud Console:
#   https://brahl.qaonair.com/api/auth/google/callback

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MEMBERSHIP=
# Webhook endpoint:
#   https://brahl.qaonair.com/api/billing/webhook

# --- AI (optional) ---
OPENAI_API_KEY=
# Or keep BYOK in FoXYiZ/f/.env on Creator machines
QOA_AI_HOSTED=0

# --- FoXYiZ engine ---
FOXYIZ_HEADLESS=true
FOXYIZ_ROOT=
# Leave empty to use KK/FoXYiZ next to qoa_web

# --- Cloud Run worker (AWS EC2) ---
# When set, projects with runtime_mode=cloud POST jobs here instead of local Popen.
FOXYIZ_CLOUD_WORKER_URL=
FOXYIZ_CLOUD_TOKEN=
# Example: https://ec2-xx.compute.amazonaws.com:8770
# Worker listens with: python FoXYiZ/pyUtils/cloud_worker_server.py
